.dos,.donts{border-radius:10px;padding:11px 12px;}
.dos{background:rgba(26,122,26,.14);border:1px solid rgba(26,122,26,.28);}
.donts{background:rgba(230,57,43,.12);border:1px solid rgba(230,57,43,.25);}
