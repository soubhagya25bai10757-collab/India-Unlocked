.agrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px;margin-top:20px;}
.acard{background:linear-gradient(135deg,rgba(139,0,0,.1),rgba(0,0,0,.2));border:1.5px solid rgba(139,0,0,.2);border-radius:16px;padding:22px;transition:all .3s;}
