function setLang(lang){
  document.querySelectorAll('.lang-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('lb-'+lang).classList.add('active');
  const t=translations[lang];
  const ids=['heroName','heroNative','heroTag','scrollLbl','lAbout','aboutTitle','lWeather','weatherTitle','lDist','distTitle','lPlaces','placesTitle','lArts','artsTitle','lTrad','tradTitle','lCuisines','cuisinesTitle','footerT'];
  ids.forEach(k=>{const el=document.getElementById(k);if(el&&t[k])el.textContent=t[k];});
  document.getElementById('distSearch').placeholder=lang==='hi'?'जिले खोजें...':lang==='ur'?'ضلع تلاش کریں...':'Search districts...';
}
