// Language setting function
function setLang(lang) {
  document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('lb-' + lang).classList.add('active');
  
  const t = translations[lang];
  
  document.getElementById('heroName').textContent = t.heroName;
  document.getElementById('heroNative').textContent = t.heroNative;
  document.getElementById('heroTag').textContent = t.heroTag;
  document.getElementById('scrollLbl').textContent = t.scrollLbl;
  document.getElementById('qw').textContent = t.weatherPill;
  document.getElementById('qd').textContent = t.districtsPill;
  document.getElementById('qp').textContent = t.placesPill;
  document.getElementById('qa').textContent = t.artsPill;
  document.getElementById('qt').textContent = t.tradPill;
  document.getElementById('qc').textContent = t.cuisinesPill;
  document.getElementById('lAbout').textContent = t.aboutLbl;
  document.getElementById('aboutTitle').textContent = t.aboutTitle;
  document.getElementById('aboutBody').textContent = t.aboutBody;
  document.getElementById('lWeather').textContent = t.weatherLbl;
  document.getElementById('weatherTitle').textContent = t.weatherTitle;
  document.getElementById('weatherNote').textContent = t.weatherNote;
  document.getElementById('lDist').textContent = t.distLbl;
  document.getElementById('distTitle').textContent = t.distTitle;
  document.getElementById('distNote').textContent = t.distNote;
  document.getElementById('distSearch').placeholder = t.distSearch;
  document.getElementById('lPlaces').textContent = t.placesLbl;
  document.getElementById('placesTitle').textContent = t.placesTitle;
  document.getElementById('lArts').textContent = t.artsLbl;
  document.getElementById('artsTitle').textContent = t.artsTitle;
  document.getElementById('lTrad').textContent = t.tradLbl;
  document.getElementById('tradTitle').textContent = t.tradTitle;
  document.getElementById('lCuisines').textContent = t.cuisinesLbl;
  document.getElementById('cuisinesTitle').textContent = t.cuisinesTitle;
  document.getElementById('footerT').textContent = t.footerT;
  document.getElementById('footerS').textContent = t.footerS;
}
