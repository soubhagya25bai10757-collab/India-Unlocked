  document.getElementById('weatherNote').textContent = t.weatherNote;
  document.getElementById('lDist').textContent = t.lDist;
  document.getElementById('distTitle').textContent = t.distTitle;
  document.getElementById('distNote').textContent = t.distNote;
  document.getElementById('distSearch').placeholder = t.distSearch;
