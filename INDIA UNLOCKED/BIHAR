function setLang(lang) {
  document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('lb-'+lang).classList.add('active');
  const t = translations[lang];
  document.getElementById('heroName').textContent = t.heroName;
  document.getElementById('heroNative').textContent = t.heroNative;
  document.getElementById('heroTag').textContent = t.heroTag;
  document.getElementById('scrollLbl').textContent = t.scrollLbl;
  document.getElementById('qw').textContent = t.qw;
  document.getElementById('qd').textContent = t.qd;
  document.getElementById('qp').textContent = t.qp;
