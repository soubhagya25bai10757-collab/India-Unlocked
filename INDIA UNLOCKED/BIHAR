// Accordion
let openAccordion = null;
function toggleAccordion(idx) {
  const accords = document.querySelectorAll('.dacc');
  if(openAccordion !== null && openAccordion !== idx) accords[openAccordion].classList.remove('open');
  accords[idx].classList.toggle('open');
  openAccordion = accords[idx].classList.contains('open') ? idx : null;
}

function filterDistricts(query) {
  document.querySelectorAll('.dacc').forEach(a => {
    a.style.display = a.dataset.name.includes(query.toLowerCase()) ? '' : 'none';
  });
}

function toggleMusic() {
  const audio = document.getElementById('bgm');
  const btn = document.getElementById('musicBtn');
  if(audio.paused){audio.play();btn.classList.add('on');}
  else{audio.pause();btn.classList.remove('on');}
}

// Fade-in observer
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); });
},{threshold:0.1});
document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

