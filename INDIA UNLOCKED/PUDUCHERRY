  document.getElementById('lb-'+lang).classList.add('active');
  const t=translations[lang];
  const ids=['heroName','heroNative','heroTag','scrollLbl','lAbout','aboutTitle','lWeather','weatherTitle','lDist','distTitle','lPlaces','placesTitle','lArts','artsTitle','lTrad','tradTitle','lCuisines','cuisinesTitle','footerT'];
