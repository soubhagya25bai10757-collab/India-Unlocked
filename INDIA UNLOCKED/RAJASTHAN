let openAccordion=null;
function toggleAccordion(idx){
  const all=document.querySelectorAll('.dacc');
  if(openAccordion!==null&&openAccordion!==idx)all[openAccordion].classList.remove('open');
  all[idx].classList.toggle('open');
  openAccordion=all[idx].classList.contains('open')?idx:null;
}
function filterDistricts(q){document.querySelectorAll('.dacc').forEach(a=>{a.style.display=a.dataset.name.includes(q.toLowerCase())?'':'none';});}
function toggleMusic(){const a=document.getElementById('bgm'),b=document.getElementById('musicBtn');if(a.paused){a.play();b.classList.add('on');}else{a.pause();b.classList.remove('on');}}
const obs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible');});},{threshold:0.08});
document.querySelectorAll('.fade-in').forEach(el=>obs.observe(el));

