function setLang(lang) {
  document.querySelectorAll('.lang-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('lb-'+lang).classList.add('active');
  const t = translations[lang];
  const map = {
    heroName:'heroName',heroNative:'heroNative',heroTag:'heroTag',scrollLbl:'scrollLbl',
    qw:'qw',qd:'qd',qp:'qp',qa:'qa',qt:'qt',qc:'qc',
    lAbout:'lAbout',aboutTitle:'aboutTitle',aboutBody:'aboutBody',
    lWeather:'lWeather',weatherTitle:'weatherTitle',weatherNote:'weatherNote',
    lDist:'lDist',distTitle:'distTitle',distNote:'distNote',
    lPlaces:'lPlaces',placesTitle:'placesTitle',
    lArts:'lArts',artsTitle:'artsTitle',
    lTrad:'lTrad',tradTitle:'tradTitle',
    lCuisines:'lCuisines',cuisinesTitle:'cuisinesTitle',
    footerT:'footerT',footerS:'footerS'
  };
  Object.entries(map).forEach(([key,id])=>{
    const el = document.getElementById(id);
    if(el && t[key]) el.textContent = t[key];
  });
  document.getElementById('distSearch').placeholder = t.distSearch;
}
