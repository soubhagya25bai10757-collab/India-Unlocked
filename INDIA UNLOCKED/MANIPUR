.wt{font-size:1.5rem;color:var(--cream);font-weight:400;margin-bottom:4px;}
.wd{font-size:.78rem;color:rgba(245,241,232,.5);font-style:italic;line-height:1.6;}
.best-tag{position:absolute;top:10px;right:10px;background:var(--emerald);color:var(--cream);font-family:"Poppins",sans-serif;font-size:.46rem;letter-spacing:.08em;padding:3px 8px;border-radius:8px;font-weight:600;}
