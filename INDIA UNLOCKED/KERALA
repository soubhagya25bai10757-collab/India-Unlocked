let openAccordion = null;
function toggleAccordion(idx) {
  const accords = document.querySelectorAll('.dacc');
  const current = accords[idx];
  if(openAccordion !== null && openAccordion !== idx) accords[openAccordion].classList.remove('open');
  current.classList.toggle('open');
  openAccordion = current.classList.contains('open') ? idx : null;
}

function filterDistricts(query) {
  const accords = document.querySelectorAll('.dacc');
  accords.forEach(a => {
    a.style.display = a.dataset.name.includes(query.toLowerCase()) ? '' : 'none';
  });
}

function toggleMusic() {
  const audio = document.getElementById('bgm');
  const btn = document.getElementById('musicBtn');
  if(audio.paused) {
    audio.play();
    btn.classList.add('on');
  } else {
    audio.pause();
    btn.classList.remove('on');
  }
}

const observer = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if(e.isIntersecting) e.target.classList.add('visible');
  });
}, {threshold: 0.1});

document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

