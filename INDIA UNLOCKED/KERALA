.agrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px;margin-top:20px;}
.acard{background:linear-gradient(135deg,rgba(0,139,139,.1),rgba(0,0,0,.2));border:1.5px solid rgba(0,139,139,.2);border-radius:16px;padding:22px;transition:all .3s;}
.acard:hover{transform:translateY(-4px);border-color:rgba(0,139,139,.5);}
.ae{font-size:2rem;display:block;margin-bottom:10px;}
