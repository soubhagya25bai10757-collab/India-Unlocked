
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gujarat — Incredible India</title>
<link href="https://fonts.googleapis.com/css2?family=Volkhov:ital,wght@0,400;0,700;1,400&family=Poppins:wght@300;400;500;600;700&family=Crimson+Text:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
<style>
:root{--saffron:#FF9933;--navy:#1a2a4e;--gold:#E6A817;--teal:#00796B;--cream:#F5F1E8;--deep:#0a0e1a;--card:#ffffff08;--border:rgba(255,153,51,0.18);}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--deep);color:var(--cream);font-family:"Crimson Text",serif;overflow-x:hidden;}
nav{position:fixed;top:0;left:0;right:0;height:54px;background:rgba(10,14,26,0.95);backdrop-filter:blur(14px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 18px;z-index:999;}
.nav-left{display:flex;align-items:center;gap:10px;}
.back-btn{width:34px;height:34px;border-radius:50%;border:1px solid var(--border);background:transparent;color:var(--saffron);font-size:.95rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .3s;}
.back-btn:hover{background:var(--saffron);color:var(--deep);}
.nav-title{font-family:"Poppins",sans-serif;font-size:.75rem;letter-spacing:.15em;color:rgba(245,241,232,.7);font-weight:600;}
.lang-bar{display:flex;gap:5px;}
.lang-btn{padding:5px 14px;border-radius:18px;border:1px solid var(--border);background:transparent;color:rgba(245,241,232,.6);font-family:"Poppins",sans-serif;font-size:.54rem;letter-spacing:.07em;cursor:pointer;transition:all .3s;font-weight:500;}
.lang-btn.active,.lang-btn:hover{background:var(--saffron);color:var(--deep);border-color:var(--saffron);}
.music-btn{width:36px;height:36px;border-radius:50%;border:1px solid var(--border);background:transparent;color:var(--saffron);font-size:1rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .3s;}
.music-btn.on,.music-btn:hover{background:var(--saffron);color:var(--deep);}
/* HERO */
.hero{height:100vh;position:relative;display:flex;flex-direction:column;align-items:center;justify-content:center;overflow:hidden;}
.hero-bg{position:absolute;inset:0;background-size:cover;background-position:center 40%;filter:brightness(.45) saturate(1.3);animation:zk 18s ease-in-out infinite alternate;}
@keyframes zk{from{transform:scale(1.05);}to{transform:scale(1.13);}}
.hero-ov{position:absolute;inset:0;background:linear-gradient(180deg,rgba(10,14,26,.1) 0%,rgba(10,14,26,.02) 35%,rgba(10,14,26,.95) 100%);}
.hero-c{position:relative;z-index:2;text-align:center;padding:0 20px;}
.hero-emoji{font-size:clamp(2rem,4vw,3.2rem);display:block;margin-bottom:.3rem;filter:drop-shadow(0 0 28px rgba(255,153,51,.8));}
.hero-name{font-family:"Poppins",sans-serif;font-size:clamp(3rem,9vw,7.5rem);color:#fff;letter-spacing:.02em;line-height:1;text-shadow:0 4px 40px rgba(0,0,0,.9);font-weight:700;}
.hero-native{font-size:clamp(1.1rem,2.8vw,2rem);color:var(--saffron);font-style:italic;letter-spacing:.1em;margin-top:.3rem;font-weight:500;}
.hero-tag{font-size:clamp(.8rem,1.6vw,1.05rem);color:rgba(245,241,232,.65);font-style:italic;letter-spacing:.1em;margin-top:.8rem;}
.tribar{display:flex;width:180px;height:5px;border-radius:2px;overflow:hidden;margin:1rem auto 0;gap:3px;}
.tribar div{flex:1;border-radius:2px;}
.qnav{position:absolute;bottom:90px;left:50%;transform:translateX(-50%);display:flex;gap:7px;flex-wrap:wrap;justify-content:center;z-index:2;}
.qpill{padding:6px 16px;border-radius:20px;border:1.5px solid rgba(255,153,51,.35);background:rgba(0,0,0,.5);backdrop-filter:blur(10px);color:rgba(245,241,232,.75);font-size:.64rem;letter-spacing:.06em;cursor:pointer;transition:all .3s;text-decoration:none;font-family:"Poppins",sans-serif;font-weight:500;}
.qpill:hover{background:var(--saffron);color:var(--deep);border-color:var(--saffron);}
.sarrow-wrap{position:absolute;bottom:22px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:5px;z-index:2;}
.sarrow-lbl{font-family:"Poppins",sans-serif;font-size:.44rem;letter-spacing:.4em;color:rgba(255,255,255,.25);font-weight:600;}
.sarrow{width:2px;height:30px;background:linear-gradient(180deg,var(--saffron),transparent);animation:sa 2s ease-in-out infinite;}
@keyframes sa{0%{opacity:0;transform:scaleY(0);transform-origin:top;}50%{opacity:1;transform:scaleY(1);}100%{opacity:0;transform:scaleY(0);transform-origin:bottom;}}
/* SECTIONS */
section{padding:60px 5vw 44px;border-top:1px solid rgba(255,153,51,.08);}
.sec-lbl{font-family:"Poppins",sans-serif;font-size:.62rem;letter-spacing:.5em;color:var(--saffron);text-transform:uppercase;margin-bottom:.5rem;display:block;font-weight:600;}
.sec-title{font-family:"Poppins",sans-serif;font-size:clamp(1.4rem,3.2vw,2.4rem);color:var(--cream);margin-bottom:.8rem;line-height:1.1;font-weight:700;}
.sec-title em{color:var(--saffron);font-style:italic;}
.sec-body{font-size:clamp(.95rem,1.6vw,1.1rem);color:rgba(245,241,232,.68);line-height:1.85;letter-spacing:.02em;}
/* WEATHER */
.wgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(165px,1fr));gap:12px;margin-top:20px;}
.wcard{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:16px;transition:all .3s;position:relative;backdrop-filter:blur(8px);}
.wcard:hover{background:rgba(255,153,51,.1);border-color:rgba(255,153,51,.45);transform:translateY(-4px);}
.wcard.best{border-color:rgba(255,153,51,.5);background:rgba(255,153,51,.08);}
.wm{font-family:"Poppins",sans-serif;font-size:.68rem;letter-spacing:.1em;color:var(--saffron);margin-bottom:4px;font-weight:600;}
.wt{font-size:1.5rem;color:var(--cream);font-weight:400;margin-bottom:4px;}
.wd{font-size:.78rem;color:rgba(245,241,232,.5);font-style:italic;line-height:1.6;}
.best-tag{position:absolute;top:10px;right:10px;background:var(--saffron);color:var(--deep);font-family:"Poppins",sans-serif;font-size:.46rem;letter-spacing:.08em;padding:3px 8px;border-radius:8px;font-weight:600;}
/* DISTRICTS */
.dsearch{width:100%;max-width:420px;padding:11px 18px;background:rgba(255,255,255,.06);border:1.5px solid var(--border);border-radius:28px;color:var(--cream);font-family:"Crimson Text",serif;font-size:1rem;outline:none;letter-spacing:.02em;margin-bottom:18px;transition:border-color .3s;display:block;font-weight:500;}
.dsearch:focus{border-color:rgba(255,153,51,.6);}
.dsearch::placeholder{color:rgba(245,241,232,.28);}
.dist-accordion{display:flex;flex-direction:column;gap:11px;}
.dacc{border:1px solid rgba(255,153,51,.16);border-radius:16px;overflow:hidden;transition:all .3s;background:rgba(255,255,255,.02);}
.dacc:hover{border-color:rgba(255,153,51,.32);background:rgba(255,153,51,.05);}
.dacc-hdr{display:flex;align-items:center;justify-content:space-between;padding:18px 22px;cursor:pointer;background:transparent;transition:all .3s;user-select:none;}
.dacc-hdr:hover{background:rgba(255,153,51,.08);}
.dacc-name{font-family:"Poppins",sans-serif;font-size:.88rem;color:var(--cream);letter-spacing:.06em;font-weight:600;}
.dacc-region{font-size:.75rem;color:var(--saffron);letter-spacing:.08em;margin-top:4px;font-weight:500;}
.dacc-arrow{color:var(--saffron);font-size:.85rem;transition:transform .35s;flex-shrink:0;font-weight:600;}
.dacc.open .dacc-arrow{transform:rotate(180deg);}
.dacc-body{max-height:0;overflow:hidden;transition:max-height .45s ease;}
.dacc.open .dacc-body{max-height:3500px;}
.dacc-inner{padding:0 22px 22px;display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:15px;}
.dinfo-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:12px;padding:16px;transition:all .3s;}
.dinfo-card:hover{border-color:rgba(255,153,51,.3);background:rgba(255,153,51,.06);}
.dinfo-title{font-family:"Poppins",sans-serif;font-size:.65rem;letter-spacing:.12em;color:var(--saffron);text-transform:uppercase;margin-bottom:10px;font-weight:600;}
.dinfo-list{list-style:none;display:flex;flex-direction:column;gap:6px;}
.dinfo-list li{font-size:.82rem;color:rgba(245,241,232,.68);line-height:1.6;display:flex;align-items:flex-start;gap:7px;}
.dinfo-list li::before{content:"◆";color:var(--saffron);flex-shrink:0;font-size:.6rem;}
.lang-chips{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;}
.lchip{padding:4px 12px;border-radius:12px;background:rgba(0,121,107,.2);border:1px solid rgba(0,121,107,.35);color:rgba(245,241,232,.75);font-size:.72rem;font-family:"Poppins",sans-serif;font-weight:500;}
.temp-row{display:flex;flex-wrap:wrap;gap:5px;margin-top:8px;}
.temp-badge{padding:4px 10px;border-radius:9px;font-size:.7rem;cursor:default;font-family:"Poppins",sans-serif;font-weight:500;}
.tb-best{background:rgba(255,153,51,.25);border:1px solid rgba(255,153,51,.5);color:var(--saffron);}
.tb-ok{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);color:rgba(245,241,232,.6);}
.tb-hot{background:rgba(230,57,43,.2);border:1px solid rgba(230,57,43,.35);color:#ffb080;}
.best-month-tag{margin-top:11px;font-size:.82rem;color:var(--saffron);font-weight:600;}
/* PLACES */
.pgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:18px;margin-top:20px;}
.pcard{background:rgba(0,121,107,.07);border:1.5px solid rgba(0,121,107,.2);border-radius:16px;overflow:hidden;transition:all .35s;position:relative;}
.pcard:hover{transform:translateY(-6px);border-color:rgba(0,121,107,.55);box-shadow:0 16px 50px rgba(0,121,107,.12);}
.pcard-acc{height:6px;background:linear-gradient(90deg,var(--saffron),var(--teal));}
.pcard-body{padding:20px;}
.pi{font-size:2rem;margin-bottom:8px;display:block;}
.pn{font-family:"Poppins",sans-serif;font-size:.82rem;color:var(--cream);letter-spacing:.05em;margin-bottom:4px;font-weight:600;}
.pl{font-size:.7rem;color:var(--teal);letter-spacing:.1em;text-transform:uppercase;margin-bottom:8px;font-weight:600;}
.pd{font-size:.8rem;color:rgba(245,241,232,.5);line-height:1.7;font-style:italic;margin-bottom:12px;}
.holy-tag{display:inline-block;background:rgba(230,57,43,.28);color:#ffb080;border:1px solid rgba(230,57,43,.4);font-size:.48rem;padding:3px 8px;border-radius:8px;margin-left:4px;vertical-align:middle;font-family:"Poppins",sans-serif;font-weight:600;}
.fee-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px;}
.fee-badge{font-size:.7rem;padding:4px 11px;border-radius:9px;font-family:"Poppins",sans-serif;font-weight:500;}
.fb-in{background:rgba(0,121,107,.22);border:1px solid rgba(0,121,107,.4);color:#7deaea;}
.fb-fr{background:rgba(230,57,43,.2);border:1px solid rgba(230,57,43,.35);color:#ffb080;}
.fb-free{background:rgba(26,122,26,.22);border:1px solid rgba(26,122,26,.4);color:#90ee90;}
.dos-donts{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-top:10px;}
.dos,.donts{border-radius:10px;padding:11px 12px;}
.dos{background:rgba(26,122,26,.14);border:1px solid rgba(26,122,26,.28);}
.donts{background:rgba(230,57,43,.12);border:1px solid rgba(230,57,43,.25);}
.dd-title{font-family:"Poppins",sans-serif;font-size:.58rem;letter-spacing:.08em;margin-bottom:6px;font-weight:600;}
.dos .dd-title{color:#90ee90;} .donts .dd-title{color:#ffb080;}
.dd-list{list-style:none;display:flex;flex-direction:column;gap:4px;}
.dd-list li{font-size:.72rem;line-height:1.5;display:flex;gap:6px;}
.dos .dd-list li{color:rgba(144,238,144,.78);} .donts .dd-list li{color:rgba(255,176,128,.72);}
/* ARTS */
.agrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px;margin-top:20px;}
.acard{background:linear-gradient(135deg,rgba(0,121,107,.1),rgba(0,0,0,.2));border:1.5px solid rgba(0,121,107,.2);border-radius:16px;padding:22px;transition:all .3s;}
.acard:hover{transform:translateY(-4px);border-color:rgba(0,121,107,.5);}
.ae{font-size:2rem;display:block;margin-bottom:10px;}
.at{font-family:"Poppins",sans-serif;font-size:.8rem;color:var(--cream);letter-spacing:.08em;margin-bottom:7px;font-weight:600;}
.ad{font-size:.78rem;color:rgba(245,241,232,.5);line-height:1.7;font-style:italic;margin-bottom:10px;}
.art-fee{font-size:.72rem;margin-bottom:10px;}
.art-fee span{padding:3px 11px;border-radius:8px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.14);color:rgba(245,241,232,.65);font-family:"Poppins",sans-serif;font-weight:500;}
footer{text-align:center;padding:50px 20px 40px;border-top:1px solid rgba(255,153,51,.08);}
footer .fe{font-size:2.2rem;display:block;margin-bottom:.6rem;}
footer .ft{font-family:"Poppins",sans-serif;font-size:.62rem;letter-spacing:.4em;color:rgba(245,241,232,.25);font-weight:600;}
footer .fs{margin-top:11px;font-size:.85rem;color:rgba(245,241,232,.35);font-style:italic;}
.fade-in{opacity:0;transform:translateY(28px);transition:opacity .7s ease,transform .7s ease;}
.fade-in.visible{opacity:1;transform:translateY(0);}
@media(max-width:600px){section{padding:44px 4vw 32px;}.wgrid{grid-template-columns:repeat(2,1fr);}.dacc-inner{grid-template-columns:1fr;}.qnav{display:none;}.dos-donts{grid-template-columns:1fr;}}
</style>
</head>
