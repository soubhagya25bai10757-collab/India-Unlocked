<script>
// Hero background image (Statue of Unity)
document.getElementById('heroBg').style.backgroundImage='url("data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 viewBox=%270 0 1200 800%27%3E%3Cdefs%3E%3ClinearGradient id=%27grd%27 x1=%270%25%27 y1=%270%25%27 x2=%27100%25%27 y2=%27100%25%27%3E%3Cstop offset=%270%25%27 style=%27stop-color:rgb(255,153,51);stop-opacity:1%27/%3E%3Cstop offset=%27100%25%27 style=%27stop-color:rgb(26,42,78);stop-opacity:1%27/%3E%3C/linearGradient%3E%3C/defs%3E%3Crect width=%271200%27 height=%27800%27 fill=%27url(%23grd)%27/%3E%3C/svg%3E")';

const districtData = [
  {name:"Ahmedabad",region:"North Gujarat",known:"Diamond Capital, Textile Hub, Sabarmati Riverfront",heritage:["Jama Masjid","Bhadra Fort","Adalaj Stepwell"],languages:["Gujarati","Hindi","English"],bestMonths:"Nov-Feb",avgTemp:"24-28°C"},
  {name:"Vadodara",region:"Central Gujarat",known:"Royal Legacy, Cultural Center, Lakshya Baroda Museum",heritage:["Lakshmi Vilas Palace","Champaner-Pavagadh","Sardar Sarovar"],languages:["Gujarati","Hindi"],bestMonths:"Nov-Feb",avgTemp:"22-26°C"},
  {name:"Surat",region:"South Gujarat",known:"Diamond Trading, Textile Commerce, Tapi Riverport",heritage:["Castle of Surat","Chintamani Jain Temple","Dutch Garden"],languages:["Gujarati","Hindi"],bestMonths:"Oct-Mar",avgTemp:"20-28°C"},
  {name:"Rajkot",region:"Saurashtra",known:"Automobile Industry, Precision Engineering, Lion Sanctuary Proximity",heritage:["Kaba Gandhi No Delo","Rajkumar College","Bandhni Printing"],languages:["Gujarati","Hindi"],bestMonths:"Nov-Feb",avgTemp:"24-30°C"},
  {name:"Junagadh",region:"Saurashtra",known:"Gir Forest Sanctuary, Ancient Stupas, Mahabat Magar Palace",heritage:["Uparkot Fort","Mahabat Magar","Gir National Park"],languages:["Gujarati","Hindi"],bestMonths:"Nov-Feb",avgTemp:"22-32°C"},
  {name:"Jamnagar",region:"Saurashtra",known:"Pearls & Salt Industry, Naval Base Proximity, Beach Tourism",heritage:["Lala Digvijay","Colonial Architecture","Jam Mandir"],languages:["Gujarati","Hindi"],bestMonths:"Oct-Mar",avgTemp:"22-30°C"},
