</section>

<section id="cuisines" class="fade-in">
  <span class="sec-lbl" id="lCuisines">Culinary Heritage</span>
  <h2 class="sec-title" id="cuisinesTitle">Flavors of <em>Gujarat</em></h2>
  <div class="agrid" id="cuisinesGrid"></div>
</section>

