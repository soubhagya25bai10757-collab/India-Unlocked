const placesData=[{emoji:"🕌",name:"Taj Mahal",location:"Agra",desc:"The world's greatest monument to love, built by Shah Jahan for Mumtaz Mahal (1631–1648). UNESCO World Heritage Site and one of the Seven Wonders of the World. At dawn the marble turns rose-pink; at dusk amber; under full moon it becomes ethereal silver.",fee:["₹50 Indians","₹1100 Foreigners"]},{emoji:"🛕",name:"Kashi Vishwanath Temple",location:"Varanasi",desc:"One of the twelve sacred Jyotirlingas of Shiva and among Hinduism's holiest sites. Located in Varanasi's 3,000-year-old lanes. The Kashi Vishwanath Corridor (2021) connects it directly to the Ganges ghats.",fee:["Free"]},{emoji:"🌊",name:"Dashashwamedh Ghat & Ganga Aarti",location:"Varanasi",desc:"The main ghat of Varanasi where priests perform the spectacular Ganga Aarti every evening at sunset. 10,000 pilgrims gather on stone steps as flames rise over the Ganges — one of earth's most moving spectacles.",fee:["Free"]},{emoji:"🏰",name:"Agra Fort",location:"Agra",desc:"Massive 16th-century Mughal fort built by Akbar. Shah Jahan spent his final 8 years imprisoned here — gazing at the Taj Mahal across the Yamuna. UNESCO World Heritage Site with palaces, mosques and audience halls.",fee:["₹35 Indians","₹550 Foreigners"]},{emoji:"🌸",name:"Ram Mandir — Ram Janmabhoomi",location:"Ayodhya",desc:"The newly consecrated Ram Mandir at the precise birthplace of Lord Ram. The grand Nagara-style temple was consecrated in January 2024 after a 500-year civilizational journey and is among the largest temples built in modern India.",fee:["Free"]},{emoji:"🏛️",name:"Fatehpur Sikri",location:"Agra District",desc:"Akbar's magnificent red sandstone capital, built in 1571 and abandoned after 14 years. The Buland Darwaza is Asia's largest gateway. A perfectly preserved UNESCO World Heritage ghost city of Mughal ambition.",fee:["₹35 Indians","₹550 Foreigners"]},{emoji:"🪷",name:"Triveni Sangam — Kumbh Mela",location:"Prayagraj",desc:"Sacred confluence of Ganga, Yamuna and