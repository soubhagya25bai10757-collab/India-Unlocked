// Render weather
const wGrid=document.getElementById('wGrid');
weatherData.forEach(w=>{wGrid.innerHTML+=`<div class="wcard${w.best?' best':''}">${w.best?'<span class="best-tag">BEST TIME</span>':''}<div class="wm">${w.month}</div><div class="wt">${w.avgTemp}</div><div class="wd">${w.details}</div></div>`;});

// Render districts
const accordion=document.getElementById('distAccordion');
districtData.forEach((d,idx)=>{
  const el=document.createElement('div');
  el.className='dacc';
  el.dataset.name=d.name.toLowerCase();
  el.innerHTML=`<div class="dacc-hdr" onclick="toggleAcc(${idx})"><div><div class="dacc-name">${d.name}</div><div class="dacc-region">${d.region}</div></div><div class="dacc-arrow">⌄</div></div><div class="dacc-body"><div class="dacc-inner"><div class="dinfo-card"><div class="dinfo-title">Known For</div><ul class="dinfo-list"><li>${d.known}</li></ul></div><div class="dinfo-card"><div class="dinfo-title">Heritage Sites</div><ul class="dinfo-list">${d.heritage.map(h=>`<li>${h}</li>`).join('')}</ul></div><div class="dinfo-card"><div class="dinfo-title">Languages</div><div class="lang-chips">${d.languages.map(l=>`<span class="lchip">${l}</span>`).join('')}</div><div class="best-month-tag">✦ Best: ${d.bestMonths}</div><div class="temp-row"><span class="temp-badge">${d.avgTemp}</span></div></div></div></div>`;
  accordion.appendChild(el);
});

// Render places
const pGrid=document.getElementById('pGrid');
placesData.forEach(p=>{
  const fees=Array.isArray(p.fee)?p.fee:[p.fee];
  pGrid.innerHTML+=`<div class="pcard"><div class="pcard-acc"></div><div class="pcard-body"><span class="pi">${p.emoji}</span><div class="pn">${p.name}</div><div class="pl">${p.location}</div><div class="pd">${p.desc}</div><div class="fee-row">${fees.map(f=>`<span class="fee-badge ${f.toLowerCase().includes('free')?'fb-free':f.includes('1100')||f.includes('550')?'fb-fr':'fb-in'}">${f}</span>`).join('')}</div><div class="dos-donts"><div class="dos"><div class="dd-title">✓ DO</div><ul class="dd-list"><li>Carry valid ID for entry</li><li>Visit Taj at sunrise</li></ul></div><div class="donts"><div class="dd-title">✗ DON'T</div><ul class="dd-list"><li>Carry food inside monuments</li><li>Photograph inside temples</li></ul></div></div></div></div>`;
});

// Render arts / traditions / cuisines
function renderGrid(id,data){
  const g=document.getElementById(id);
  data.forEach(i=>{g.innerHTML+=`<div class="acard"><span class="ae">${i.emoji}</span><div class="at">${i.name}</div><div class="ad">${i.desc}</div><div class="art-fee"><span>${i.location||i.region}</span></div></div>`;});
}
renderGrid('artGrid',artsData);
renderGrid('tradGrid',traditionsData);
renderGrid('cuisinesGrid',cuisinesData);

// Accordion
let openIdx=null;
function toggleAcc(idx){
  const all=document.querySelectorAll('.dacc');
  if(openIdx!==null&&openIdx!==idx)all[openIdx].classList.remove('open');
  all[idx].classList.toggle('open');
  openIdx=all[idx].classList.contains('open')?idx:null;
}

function filterDistricts(q){
  document.querySelectorAll('.dacc').forEach(a=>{a.style.display=a.dataset.name.includes(q.toLowerCase())?'':'none';});
}

function toggleMusic(){
  const a=document.getElementById('bgm'),b=document.getElementById('musicBtn');
  if(a.paused){a.play();b.textContent='🔇';}else{a.pause();b.textContent='🎵';}
}

// Fade in
const obs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible');});},{threshold:0.08});
document.querySelectorAll('.fade-in').forEach(el=>obs.observe(el));

