function setLang(lang){
  document.querySelectorAll('.lang-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('lb-'+lang).classList.add('active');
  const t=translations[lang];
  const keys=['heroName','heroNative','heroTag','scrollLbl','qw','qd','qp','qa','qt','qc','lAbout','aboutTitle','aboutBody','lWeather','weatherTitle','weatherNote','lDist','distTitle','distNote','lPlaces','placesTitle','lArts','artsTitle','lTrad','tradTitle','lCuisines','cuisinesTitle','footerT','footerS'];
  keys.forEach(k=>{const el=document.getElementById(k);if(el&&t[k])el.textContent=t[k];});
  document.getElementById('distSearch').placeholder=t.distSearch;
}
