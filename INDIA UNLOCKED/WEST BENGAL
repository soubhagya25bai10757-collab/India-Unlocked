    'lDist','distTitle','distNote','lPlaces','placesTitle','lArts','artsTitle',
    'lTrad','tradTitle','lCuisines','cuisinesTitle','footerT','footerS'];
  keys.forEach(k => {
    const el = document.getElementById(k);
    if(el && t[k]) el.textContent = t[k];
  });
  document.getElementById('distSearch').placeholder = t.distSearch;
}
